<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="CustomInputField">
        <!-- Hint -->
        <attr name="hintText" format="string" />

        <!-- Icons -->
        <attr name="hintIcon" format="reference" />
        <attr name="endIcon" format="reference" />

        <!-- background -->
        <attr name="activeBackground" format="reference" />
        <attr name="inactiveBackground" format="reference" />

        <!-- Color -->
        <attr name="hintColor" format="color" />
        <attr name="textColor" format="color" />

        <!-- Fonts and Size -->
        <attr name="hintSize" format="dimension" />
        <attr name="hintFamily" format="string" />

    </declare-styleable>
</resources>