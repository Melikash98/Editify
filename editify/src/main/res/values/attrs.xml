<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="CustomInputField">
        <!-- Hint -->
        <attr name="hintText" format="string" />
        <attr name="input" format="string" />
        <attr name="helperText" format="string" />
        <attr name="warningText" format="string" />
        <attr name="errorText" format="string" />


        <!-- Icons -->
        <attr name="hintIcon" format="reference" />
        <attr name="passShow" format="reference" />
        <attr name="passHide" format="reference" />
        <attr name="helperIcon" format="reference" />
        <attr name="warningIcon" format="reference" />
        <attr name="errorIcon" format="reference" />


        <!-- background -->
        <attr name="activeBackground" format="reference" />
        <attr name="inactiveBackground" format="reference" />
        <attr name="hintBackgroundColor" format="color" />

        <!-- Color -->
        <attr name="hintColor" format="color" />
        <attr name="hintActiveColor" format="color" />
        <attr name="iconHintColor" format="color" />
        <attr name="textColor" format="color" />
        <attr name="inputColor" format="color" />
        <attr name="passIconColor" format="color" />
        <attr name="helperColor" format="color" />
        <attr name="warningColor" format="color" />
        <attr name="errorColor" format="color" />


        <!-- Fonts and Size -->
        <attr name="hintSize" format="dimension" />
        <attr name="hintFamily" format="string|reference" />
        <attr name="inputSize" format="dimension" />
        <attr name="inputFamily" format="string|reference" />
        <attr name="helperSize" format="dimension" />
        <attr name="helperFamily" format="string|reference" />

        <!-- Style -->
        <attr name="inputType" format="integer" />

        <!--right and left -->
        <attr name="rightDirection" format="boolean" />

    </declare-styleable>
</resources>