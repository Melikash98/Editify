<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="CustomInputField">
        <!-- متن و hint -->
        <attr name="hint" format="string" />
        <attr name="text" format="string" />

        <!-- آیکون‌ها -->
        <attr name="startIcon" format="reference" />
        <attr name="endIcon" format="reference" />
        <attr name="showPasswordToggle" default="false" format="boolean" />
        <attr name="passwordToggleIcon" format="reference" />
        <!-- background -->
        <attr name="activeBackground" format="reference" />
        <attr name="inactiveBackground" format="reference" />

        <!-- رنگ‌ها -->
        <attr name="hintColor" format="color" />
        <attr name="textColor" format="color" />
        <attr name="iconColor" format="color" />
        <attr name="helperErrorColor" format="color" />
        <attr name="helperSuccessColor" format="color" />

        <!-- فونت و اندازه -->
        <attr name="textSize" format="dimension" />
        <attr name="fontFamily" format="string" />

    </declare-styleable>
</resources>