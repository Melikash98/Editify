<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/backInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_inactive"
            android:padding="10dp"
            tools:ignore="MissingConstraints">

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/editInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/hintLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                app:layout_constraintBottom_toBottomOf="@id/editInput"
                app:layout_constraintStart_toStartOf="@id/editInput"
                app:layout_constraintTop_toTopOf="@id/editInput">

                <ImageView
                    android:id="@+id/iconStart"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/icons"
                    app:tint="@color/gray" />

                <TextView
                    android:id="@+id/hintText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Hint"
                    android:textAlignment="center"
                    android:textColor="@color/gray"
                    android:textFontWeight="800"
                    android:textSize="18sp"
                    app:layout_constraintStart_toEndOf="@id/iconStart"
                    app:layout_constraintTop_toTopOf="@id/iconStart" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <ImageView
                android:id="@+id/iconEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:src="@drawable/ic_error"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/helperBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginTop="15dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/backInput"
            app:layout_constraintTop_toBottomOf="@id/backInput">

            <ImageView
                android:id="@+id/helpIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/helper"
                android:backgroundTint="@color/green"
                tools:ignore="MissingConstraints" />

            <TextView
                android:id="@+id/helperText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:text="Helper"
                android:textColor="@color/green"
                android:textFontWeight="800"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="@id/helpIcon"
                app:layout_constraintStart_toEndOf="@id/helpIcon"
                app:layout_constraintTop_toTopOf="@id/helpIcon"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/wrongBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginTop="15dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/backInput"
            app:layout_constraintTop_toBottomOf="@id/backInput">

            <ImageView
                android:id="@+id/warningIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/warning"
                android:backgroundTint="@color/yellow" />

            <TextView
                android:id="@+id/warningText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:text="Warning"
                android:textColor="@color/yellow"
                android:textFontWeight="800"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="@id/warningIcon"
                app:layout_constraintStart_toEndOf="@id/warningIcon"
                app:layout_constraintTop_toTopOf="@id/warningIcon" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/errorBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginTop="15dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/backInput"
            app:layout_constraintTop_toBottomOf="@id/backInput">

            <ImageView
                android:id="@+id/errorIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/ic_error"
                android:backgroundTint="@color/red"
                tools:ignore="MissingConstraints" />

            <TextView
                android:id="@+id/errorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:text="Error"
                android:textColor="@color/red"
                android:textFontWeight="800"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="@id/errorIcon"
                app:layout_constraintStart_toEndOf="@id/errorIcon"
                app:layout_constraintTop_toTopOf="@id/errorIcon" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>